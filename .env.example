# ============================================
# ET-Hunter / Jaegeren Community
# Environment Variables Template
# ============================================
# Copy to .env.local and fill in actual values
# NEVER commit .env.local to git

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- App ---
VITE_APP_URL=http://localhost:5173

# ============================================
# Server-side / MCP / Infrastructure
# (Not VITE_ prefixed — not exposed to client)
# ============================================

# --- Supabase (server-side) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- VPS / Infrastructure ---
VPS_HOST=0.0.0.0
VPS_USER=root
HCLOUD_TOKEN=your-hetzner-cloud-token

# --- n8n Workflow Automation ---
N8N_BASE_URL=http://your-vps-ip:5678
N8N_API_URL=http://your-vps-ip:5678/api/v1
N8N_API_KEY=your-n8n-api-key

# --- AI/ML Services ---
PINECONE_API_KEY=your-pinecone-api-key
BRAVE_API_KEY=your-brave-api-key
TAVILY_API_KEY=your-tavily-api-key
EXA_API_KEY=your-exa-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
E2B_API_KEY=your-e2b-api-key
REPLICATE_API_TOKEN=your-replicate-api-token
LLAMA_CLOUD_API_KEY=your-llamacloud-api-key

# --- Monitoring ---
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
